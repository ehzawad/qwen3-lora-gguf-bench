# Downloaded and generated model artifacts
/models/
/artifacts/

# Pulled source and build products
/vendor/
/build/

# Runtime state and unsanitized logs
/logs/
/run/
/tmp/
/cache/
**/.cache/

# Virtual environments and Python caches
/.venv*/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/

# Model weights and large binary formats: defense in depth
*.safetensors
*.gguf
*.gguf.*
*.bin
*.pt
*.pth
*.ckpt
*.onnx
*.tflite

# Compiled binaries/libraries
*.o
*.a
*.so
*.dylib
*.dll
*.exe

# Secrets and local overrides
.env
.env.*
!.env.example
*.pem
*.key

# Editor/OS noise
.DS_Store
.vscode/
.idea/
results/current_run.txt

# Verbose per-slot server logs (the startup line is captured in the derived JSON).
# NOTE: ppl-*.log (perplexity output) is intentionally NOT matched — it's small
# accuracy evidence and is committed.
results/**/server-*.log
results/**/server.log
results/**/srv*.log
results/**/*.err

# Locust auto-generated HTML reports (redundant with CSV/JSON)
results/**/*.html

# Downloaded eval datasets (regenerated by scripts/prepare_data.py)
/data/
scripts/__pycache__/

# Transient scratch files (council/audit prompts + outputs)
scratch_*
